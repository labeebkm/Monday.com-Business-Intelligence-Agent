# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/

# ------------------------------------------------------------
# Environment files and secrets
# Keep example env templates committed, ignore real env files.
# ------------------------------------------------------------
.env
.env.*
!.env.local
!.env.example

# ------------------------------------------------------------
# Next.js / Node.js build outputs
# ------------------------------------------------------------
.next/
out/
dist/
build/
.turbo/

# ------------------------------------------------------------
# Runtime logs and debug files
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------
# TypeScript incremental build metadata
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# Test and coverage artifacts
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# Deployment and platform metadata
# ------------------------------------------------------------
.vercel/

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Editor / IDE files
# ------------------------------------------------------------
.vscode/
.idea/
*.iml

# ------------------------------------------------------------
# Keep lockfile tracked for reproducible npm installs
# ------------------------------------------------------------
!package-lock.json
